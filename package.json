{
  "name": "f-land",
  "private": true,
  "type": "module",
  "version": "0.1.5",
  "author": "FapLandDev",
  "description": "Fap Land — Party Edition",
  "license": "AGPL-3.0-only",
  "repository": "https://github.com/FapLandPartyDev/FapLand-Party-Edition",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:multiplayer": "./scripts/dev-multiplayer.sh",
    "build": "vite build",
    "build:release": "cross-env FLAND_BUILD_PROFILE=release vite build",
    "build:package": "cross-env FLAND_BUILD_PROFILE=release vite build && electron-builder --publish never",
    "build:analyze": "cross-env FLAND_BUILD_PROFILE=release FLAND_BUILD_ANALYZE=true vite build",
    "build:testers": "cross-env FLAND_BUILD_PROFILE=release FLAND_ENABLE_DEV_FEATURES=true vite build && electron-builder --publish never",
    "build:dev": "cross-env FLAND_BUILD_PROFILE=default FLAND_ENABLE_DEV_FEATURES=true vite build --mode development && electron-builder --publish never",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "prettier --write .",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "supabase:local:setup": "./scripts/setup-supabase-local.sh",
    "supabase:migrate": "./scripts/migrate-supabase-local.sh",
    "supabase:deploy:prod": "./scripts/deploy-supabase-prod.sh",
    "supabase:reset": "nix develop -c supabase stop && nix develop -c supabase start"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hey-api/openapi-ts": "^0.94.5",
    "@libsql/client": "^0.17.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@pixi/react": "^8.0.5",
    "@supabase/supabase-js": "^2.100.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.168.8",
    "@tanstack/react-virtual": "^3.13.23",
    "@tanstack/router-plugin": "^1.167.9",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.12.0",
    "drizzle-orm": "^0.45.2",
    "electron-store": "^11.0.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "framer-motion": "^12.38.0",
    "pixi.js": "^8.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superjson": "^2.2.6",
    "systeminformation": "^5.31.5",
    "tailwindcss": "^4.2.0",
    "trpc-electron": "^0.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "javascript-obfuscator": "^5.4.1",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "web-vitals": "^5.2.0"
  },
  "build": {
    "appId": "com.fland.app",
    "productName": "Fap Land",
    "afterPack": "./build/after-pack-hook.cjs",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "compression": "normal",
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "loadBrowserProcessSpecificV8Snapshot": true,
      "grantFileProtocolExtraPrivileges": false
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist/**/*.map",
      "!dist-electron/**/*.map"
    ],
    "extraResources": [
      "drizzle/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "executableArgs": [
        "--enable-features=UseOzonePlatform,WaylandWindowDecorations",
        "--ozone-platform-hint=auto"
      ],
      "category": "Game"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "perMachine": false
    },
    "fileAssociations": [
      {
        "ext": "hero",
        "name": "F-Land Hero Sidecar",
        "role": "Viewer"
      },
      {
        "ext": "round",
        "name": "F-Land Round Sidecar",
        "role": "Viewer"
      },
      {
        "ext": "fplay",
        "name": "F-Land Playlist",
        "role": "Viewer"
      }
    ],
    "protocols": [
      {
        "name": "F-Land Auth Callback",
        "schemes": [
          "fland"
        ]
      }
    ],
    "publish": [
      "github"
    ]
  }
}
