{
  "name": "f-land",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "author": "FapLandDev",
  "description": "Fap Land — Party Edition",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:multiplayer": "./scripts/dev-multiplayer.sh",
    "build": "vite build",
    "build:release": "cross-env FLAND_BUILD_PROFILE=release vite build",
    "build:analyze": "cross-env FLAND_BUILD_PROFILE=release FLAND_BUILD_ANALYZE=true vite build",
    "build:dev": "npm run build:release && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "prettier --write .",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "supabase:local:setup": "./scripts/setup-supabase-local.sh",
    "supabase:migrate": "supabase db push --local",
    "supabase:deploy:prod": "./scripts/deploy-supabase-prod.sh",
    "supabase:reset": "nix develop -c supabase stop && nix develop -c supabase start"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hey-api/openapi-ts": "^0.94.1",
    "@libsql/client": "^0.17.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@pixi/react": "^8.0.5",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.3",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/router-plugin": "^1.166.12",
    "@trpc/client": "^11.13.4",
    "@trpc/react-query": "11.13.4",
    "drizzle-orm": "^0.45.1",
    "electron-store": "^11.0.2",
    "electron-trpc": "^0.7.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "framer-motion": "^12.36.0",
    "pixi.js": "^8.17.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superjson": "^2.2.6",
    "systeminformation": "^5.31.4",
    "tailwindcss": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.0.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^41.0.2",
    "electron-builder": "^26.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "javascript-obfuscator": "^5.3.0",
    "terser": "^5.39.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0",
    "web-vitals": "^5.1.0"
  },
  "build": {
    "appId": "com.fland.app",
    "productName": "Fap Land",
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      "drizzle/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "executableArgs": [
        "--enable-features=UseOzonePlatform,WaylandWindowDecorations",
        "--ozone-platform-hint=auto"
      ],
      "category": "Game"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "perMachine": true
    },
    "fileAssociations": [
      {
        "ext": "hero",
        "name": "F-Land Hero Sidecar",
        "role": "Viewer"
      },
      {
        "ext": "round",
        "name": "F-Land Round Sidecar",
        "role": "Viewer"
      },
      {
        "ext": "fplay",
        "name": "F-Land Playlist",
        "role": "Viewer"
      }
    ],
    "publish": [
      "github"
    ]
  }
}
